def processar_vendas():

  total_compra = 0.0

  itens_comprados = 0



  try:

    quantidade_tipos = int(input("Quantos produtos diferentes foram comprados? "))

  except ValueError:

    print("Erro: Por favor, digite um número inteiro para a quantidade de produtos.")

    return



  for i in range(1, quantidade_tipos + 1):

    print(f"\n--- Produto {i} ---")

    nome = input("Nome do produto: ")

    

    try:

      preco = float(input(f"Preço unitário de {nome}: "))

      qtd = int(input(f"Quantidade de {nome}: "))

    except ValueError:

      print("Erro: Preço ou quantidade inválidos. Pulando este item.")

      continue



    if preco <= 0 or qtd <= 0:

      print(f"Erro: Valores inválidos para {nome}. O preço e a quantidade devem ser maiores que zero.")

    else:

      subtotal = preco * qtd

      total_compra += subtotal

      itens_comprados += qtd



  # Aplicação de descontos progressivos

  if total_compra > 500.00:

    total_final = total_compra * 0.90 # 10% de desconto

    print("\nDesconto de 10% aplicado!")

  elif total_compra > 200.00:

    total_final = total_compra * 0.95 # 5% de desconto

    print("\nDesconto de 5% aplicado!")

  else:

    total_final = total_compra

    print("\nSem desconto aplicado.")



  

  print("-" * 30)

  print(f"Resumo: {itens_comprados} itens.")

  print(f"Total a pagar: R${total_final:.2f}")

  print("-" * 30)



if __name__ == "__main__":

  processar_vendas()



