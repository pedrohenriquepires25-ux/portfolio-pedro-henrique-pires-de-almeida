def sistema_notas_turma():

  

  try:

    total_alunos = int(input("Quantos alunos existem na turma? "))

  except ValueError:

    print("Por favor, digite um número inteiro válido.")

    return



  

  for j in range(1, total_alunos + 1):

    print(f"\n--- Aluno {j} ---")

    aluno_nome = input("Nome do aluno: ")

    

    # Lê as notas e converte para float

    try:

      n1 = float(input("Nota 1: "))

      n2 = float(input("Nota 2: "))

    except ValueError:

      print("Nota inválida. Por favor, use números.")

      continue



    # Calcula a média

    media_aluno = (n1 + n2) / 2



    # Lógica de decisão (Aprovado, Recuperação ou Reprovado)

    if media_aluno >= 7.0:

      print(f"{aluno_nome}: Aprovado com média {media_aluno:.2f}")

    elif media_aluno >= 5.0:

      print(f"{aluno_nome}: Recuperação (Média: {media_aluno:.2f})")

    else:

      print(f"{aluno_nome}: Reprovado (Média: {media_aluno:.2f})")



# Chama a função

if __name__ == "__main__":

  sistema_notas_turma()



