def simulador_poupanca():

  # Entrada de dados iniciais

  try:

    saldo = float(input("Valor inicial do investimento: "))

    taxa = float(input("Taxa de juros mensal (em %): "))

    meses = int(input("Número de meses da simulação: "))

  except ValueError:

    print("Erro: Por favor, insira valores numéricos válidos.")

    return



  atingiu_meta = False



  # Loop para simulação mensal

  for m in range(1, meses + 1):

    try:

      aporte = float(input(f"Quanto deseja depositar no mês {m}? (0 para nenhum): "))

    except ValueError:

      print("Valor inválido. Considerando aporte de R$0.00")

      aporte = 0.0



    

    saldo += aporte

    juros = saldo * (taxa / 100)

    saldo += juros



    print(f"Mês {m}: Saldo atualizado = R${saldo:.2f}")



    

    if saldo > 10000.0 and not atingiu_meta:

      print(f"Parabéns! Você atingiu a meta de 10k no mês {m}")

      atingiu_meta = True



  

  print(f"\nResultado final após {meses} meses: R${saldo:.2f}")



if __name__ == "__main__":

  simulador_poupanca()



